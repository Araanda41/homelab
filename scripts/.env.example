# Discord webhook URL where alerts are sent 
DISCORD_WEBHOOK_URL=

# Display name for the bot in Discord
DISCORD_USERNAME=Homelab Monitor

# Hostname shown in the alert footer (defaults to the system hostname)
MONITOR_HOSTNAME=

# Warning thresholds in percentages
DISK_WARN=85
RAM_WARN=90
TEMP_WARN=75

# CPU load alert = cores * this value
LOAD_WARN_FACTOR=2

# Mount points to always check
DISKS=/

# Extra mount points to check only if mounted (space-separated)
EXTRA_DISKS=/mnt/das

# Where state files are kept to detect transitions
STATE_DIR=/tmp/monitor-recursos